# ========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ========================================
# URL de conexión a PostgreSQL (usar asyncpg si usas async, o psycopg2 si es sync)
# Para async: postgresql+asyncpg://user:pass@host:port/db
# Para sync: postgresql://user:pass@host:port/db
DATABASE_URL=

# Esquema de la base de datos (opcional, si usas múltiples esquemas en PostgreSQL)
DATABASE_SCHEMA=

# ========================================
# CONFIGURACIÓN DE JWT
# ========================================
# Clave secreta para firmar tokens JWT (¡genera una aleatoria y única en producción!)
SECRET_KEY=
# Algoritmo de firma JWT (no cambies a menos que sepas lo que haces)
ALGORITHM=
# Tiempo de expiración del token de acceso (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=
# Tiempo de expiración del token de refresco (en minutos) — 1 día = 1440 min
REFRESH_TOKEN_EXPIRE_MINUTES=

# ========================================
# CONFIGURACIÓN DE REDIS
# ========================================
# URL de conexión a Redis (usado para Celery, blacklist de tokens, cache)
REDIS_URL=
REDIS_HOST=
REDIS_PORT=
REDIS_DB=
REDIS_PASSWORD=

# ========================================
# CONFIGURACIÓN DE CELERY
# ========================================
# Broker y backend de resultados (ambos apuntan a Redis)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# Opcional: Tiempo de espera para tareas (en segundos)
CELERY_TASK_TIME_LIMIT=
# Opcional: Número de workers en producción
CELERY_WORKER_CONCURRENCY=

# ========================================
# CONFIGURACIÓN DE CORREO (EMAIL SERVICE)
# ========================================
# URL del servicio de envío de correos externo
# Este sistema usa un servicio de correo dedicado para enviar notificaciones
EMAIL_SERVICE_URL=http://localhost:8002

# NOTA: Las siguientes variables SMTP ya NO se usan directamente en este servicio.
# Se mantienen documentadas para referencia o si quieres usar otro método de envío.
# Si deseas revertir a SMTP directo, descomenta estas líneas:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_NAME=Sistema de Autenticación
# SMTP_FROM_EMAIL=your-email@gmail.com

# ========================================
# CONFIGURACIÓN DE FASTAPI
# ========================================
# Título de la API
API_TITLE=
# Descripción de la API
API_DESCRIPTION=
# Versión de la API
API_VERSION=
# Host de desarrollo (no cambiar en producción)
API_HOST=
# Puerto de desarrollo
API_PORT=

# ========================================
# CONFIGURACIÓN DE LOGGING
# ========================================
# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=
# Formato de los logs
LOG_FORMAT=
# Archivo de logs (opcional, descomentar para guardar en archivo)
# LOG_FILE=logs/auth-system.log

# ========================================
# CONFIGURACIÓN DE ENTORNO
# ========================================
# Entorno actual: development, staging, production
ENVIRONMENT=
# Habilitar modo debug (solo en desarrollo — desactivar en producción)
DEBUG=

# ========================================
# CONFIGURACIÓN DE CORS
# ========================================
# Dominios permitidos para CORS (separados por comas, sin espacios)
ALLOWED_ORIGINS=

# ========================================
# CONFIGURACIÓN DE SEGURIDAD
# ========================================
# Máximo de intentos de login antes de bloquear temporalmente
MAX_LOGIN_ATTEMPTS=
# Tiempo de bloqueo tras intentos fallidos (en segundos)
LOGIN_LOCKOUT_TIME=

# ========================================
# CONFIGURACIÓN DE AUDITORÍA
# ========================================
# Habilitar registro de eventos de acceso (recomendado en producción)
AUDIT_ENABLED=
# Retención de logs de auditoría en días (eliminación automática)
AUDIT_RETENTION_DAYS=

# ========================================
# CONFIGURACIÓN DE TAREAS ASÍNCRONAS
# ========================================
# Tiempo máximo de ejecución de una tarea (en segundos)
TASK_TIMEOUT=

# ========================================
# CONFIGURACIÓN ADICIONAL (OPCIONAL)
# ========================================
# Salt adicional para hashing (útil si necesitas doble capa de seguridad)
# PASSWORD_SALT=optional-additional-salt

# Clave para encriptar datos sensibles (ej. tokens de terceros, datos personales)
# ENCRYPTION_KEY=your-32-byte-encryption-key-here1234567890abcdef

# ========================================
# CONFIGURACIÓN DE MIGRACIONES (ALEMBIC)
# ========================================
# Si usas migraciones con múltiples esquemas, define el nombre del esquema aquí
ALEMBIC_SCHEMA=

# ========================================
# CONFIGURACIÓN DE SERVICIOS EXTERNOS
# ========================================
# URL del servicio de autenticación (si este sistema es el central)
AUTH_SERVICE_URL=

# URL del servicio de reservas (u otro microservicio)
RESERVAS_SERVICE_URL=
# URL del servicio de env�o de correos
EMAIL_SERVICE_URL=http://localhost:8002

# URL del frontend (usado para enlaces de verificaci�n, etc.)
FRONTEND_URL=http://localhost:5173
